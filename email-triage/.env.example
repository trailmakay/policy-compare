# Copy this file to ".env" and fill in your Anthropic API key.
# Get a key at https://console.anthropic.com/ -> Settings -> API Keys
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override the model (defaults to Claude Opus 4.8)
# TRIAGE_MODEL=claude-opus-4-8

# --- Emailing the digest (only needed for `--email` / the scheduler) ---------
# For a Gmail sender: turn on 2-Step Verification, then create an App Password
# (Google Account -> Security -> App passwords) and use it as SMTP_PASSWORD.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-16-char-app-password
EMAIL_FROM=you@gmail.com
# Comma-separated. Put the client here; add yourself to keep an eye on it.
EMAIL_TO=client@theircompany.com,you@gmail.com

# Time the scheduler sends the digest each day (24h, local time)
DAILY_RUN_TIME=07:00
